{
    "name": "fastedgy-template",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "web-types": "./web/web-types.json",
    "workspaces": [
        "web"
    ],
    "scripts": {
        "dev": "cd web && vite",
        "build": "cd web && NODE_OPTIONS='--max-old-space-size=4096' vite build",
        "preview": "cd web && vite preview",
        "test": "cd web && vitest run",
        "test:watch": "cd web && vitest",
        "lint": "oxlint . --type-aware",
        "fix": "oxlint --fix",
        "format": "oxfmt --write ./web/src"
    },
    "dependencies": {
        "@cyhnkckali/vue3-color-picker": "^2.1.5",
        "@headlessui/vue": "^1.7.23",
        "@iconify/vue": "^5.0.0",
        "@internationalized/date": "^3.9.0",
        "@tailwindcss/vite": "^4.1.11",
        "@tanstack/vue-table": "^8.21.3",
        "@tiptap/extension-color": "^3.5.0",
        "@tiptap/extension-highlight": "^3.5.0",
        "@tiptap/extension-text-align": "^3.5.0",
        "@tiptap/extension-text-style": "^3.5.0",
        "@tiptap/extension-underline": "^3.5.0",
        "@tiptap/extension-youtube": "^3.10.1",
        "@tiptap/starter-kit": "^3.5.0",
        "@tiptap/vue-3": "^3.5.0",
        "@unovis/ts": "^1.6.1",
        "@unovis/vue": "^1.6.1",
        "@vueuse/core": "^13.9.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lodash": "^4.17.21",
        "lucide-vue-next": "^0.525.0",
        "pinia": "^2.1.7",
        "radix-vue": "^1.9.17",
        "reka-ui": "^2.5.1",
        "shadcn-vue": "^2.2.0",
        "tailwind-merge": "^3.3.1",
        "tw-animate-css": "^1.3.5",
        "vue": "^3.4.15",
        "vue-draggable-plus": "^0.6.0",
        "vue-fastedgy": "github:krafterio/vue-fastedgy#main",
        "vue-i18n": "^11.1.12",
        "vue-router": "^4.2.5",
        "vue-sonner": "^2.0.2",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.16",
        "@vitejs/plugin-vue": "^5.2.3",
        "@vue/test-utils": "^2.4.4",
        "autoprefixer": "^10.4.21",
        "jsdom": "^24.0.0",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.23.0",
        "postcss": "^8.5.6",
        "prettier": "3.8.1",
        "sass": "^1.86.3",
        "tailwindcss": "^4.1.11",
        "vite": "^6.2.6",
        "vitest": "^3.1.2"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
